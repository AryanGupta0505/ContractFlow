// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())

  users       Membership[]
  contracts   Contract[]
  workflows   Workflow[]
  templates   Template[]
}
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  avatarUrl     String?
  preferences   Json?
  emailVerified DateTime?
  status        UserStatus @default(ACTIVE)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())

  accounts      Account[]
  memberships   Membership[]
  contracts     Contract[] @relation("CreatedContracts")
}

model Account {
  id                String @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}
model Membership {
  id              String @id @default(uuid())
  userId          String
  organizationId  String
  role            Role

  user            User @relation(fields: [userId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}
model Contract {
  id              String   @id @default(uuid())
  organizationId  String
  title           String
  status          ContractStatus
  createdBy       String
  workflowId      String?
  templateId      String?

  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  creator         User         @relation("CreatedContracts", fields: [createdBy], references: [id])
  workflow        Workflow?    @relation(fields: [workflowId], references: [id])
  template        Template?    @relation(fields: [templateId], references: [id])
  versions        ContractVersion[]
  approvals       Approval[]
  signatures      Signature[]
  aiData          ContractAI?
}
model ContractVersion {
  id          String   @id @default(uuid())
  contractId  String
  version     Int
  contentJson Json
  fileUrl     String?
  createdAt   DateTime @default(now())

  contract    Contract @relation(fields: [contractId], references: [id])
}
model ContractAI {
  id          String @id @default(uuid())
  contractId  String @unique
  summary     String?
  riskScore   String?
  clauses     Json?

  contract    Contract @relation(fields: [contractId], references: [id])
}
model Workflow {
  id              String   @id @default(uuid())
  organizationId  String
  name            String

  organization    Organization @relation(fields: [organizationId], references: [id])
  contracts       Contract[]
  steps           WorkflowStep[]
  templates       Template[]
}

model Template {
  id              String   @id @default(uuid())
  organizationId  String
  name            String
  type            String
  workflowId      String?
  contentJson     Json
  createdAt       DateTime @default(now())

  organization    Organization @relation(fields: [organizationId], references: [id])
  workflow        Workflow?    @relation(fields: [workflowId], references: [id])
  contracts       Contract[]
}
model WorkflowStep {
  id          String @id @default(uuid())
  workflowId  String
  order       Int
  role        Role
  condition   String?

  workflow    Workflow @relation(fields: [workflowId], references: [id])

  @@unique([workflowId, order])
}
model Approval {
  id          String   @id @default(uuid())
  contractId  String
  stepId      String
  userId      String
  status      ApprovalStatus
  comment     String?
  createdAt   DateTime @default(now())

  contract    Contract @relation(fields: [contractId], references: [id])
}
model Signature {
  id          String   @id @default(uuid())
  contractId  String
  email       String
  signedAt    DateTime?
  status      SignatureStatus

  contract    Contract @relation(fields: [contractId], references: [id])
}
model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  data        Json
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
model AuditLog {
  id          String   @id @default(uuid())
  organizationId String
  userId      String
  action      String
  entityType  String
  entityId    String
  createdAt   DateTime @default(now())
}
enum ContractStatus {
  DRAFT
  PENDING
  APPROVED
  SIGNED
  ARCHIVED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SignatureStatus {
  PENDING
  SIGNED
}
